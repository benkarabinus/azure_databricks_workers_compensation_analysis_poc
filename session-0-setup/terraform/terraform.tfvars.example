# Copy this file to terraform.tfvars and edit the values.
# terraform.tfvars is gitignored so your settings stay local.

# Azure subscription to deploy into. Alternatively, leave this out and export
# ARM_SUBSCRIPTION_ID before running Terraform.
subscription_id = "00000000-0000-0000-0000-000000000000"

# Prefix used in the Unity Catalog external location names (<prefix>_landing,
# <prefix>_managed). Constraint: 2-10 lowercase letters/digits.
prefix = "sfpoc"

# Azure region. Must support Databricks serverless compute.
location = "westus2"

# Resource group: create a new one (true) or reuse an existing one (false).
# Constraint: 1-90 chars; letters, digits, hyphens, underscores, parentheses,
# periods; cannot end with a period.
create_resource_group = true
resource_group_name   = "rg-state-fund-poc"

# ADLS Gen2 containers. Constraint: 3-63 chars, lowercase letters/digits/hyphens
# only (NO uppercase, NO underscores); must start and end with a letter or digit.
landing_container = "landing"
managed_container = "state-fund-poc-managed"

# --- Explicit resource names (no autogenerated suffixes) ---------------------
# Storage account. Constraint: 3-24 chars, lowercase letters/digits only;
# globally unique across all of Azure.
storage_account_name = "sfpoclakehouse"

# Databricks workspace. Constraint: 3-64 chars; letters, digits, hyphens, underscores.
workspace_name = "dbw-state-fund-poc"

# Databricks access connector (managed identity). Constraint: 3-64 chars;
# letters, digits, hyphens, underscores, periods.
access_connector_name = "ac-state-fund-poc"

tags = {
  project = "state-fund-lane1-poc"
  env     = "poc"
}

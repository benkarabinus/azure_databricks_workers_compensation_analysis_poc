{
  "name": "state_fund_poc_end_to_end",
  "description": "Reference Workflow: ingest -> Bronze -> Silver -> Gold -> score -> quality. Replace the <...> placeholders (pipeline IDs and notebook paths) with your workspace values, then import via Jobs & Pipelines > Create > Job (or the Jobs API). All tasks run on Serverless.",
  "tasks": [
    {
      "task_key": "ingest_excel",
      "notebook_task": {
        "notebook_path": "/Workspace/<your-folder>/session-1-bronze/ingest_adjuster_notes_excel"
      },
      "environment_key": "serverless"
    },
    {
      "task_key": "bronze_pipeline",
      "pipeline_task": { "pipeline_id": "<BRONZE_PIPELINE_ID>" }
    },
    {
      "task_key": "silver_pipeline",
      "depends_on": [
        { "task_key": "bronze_pipeline" },
        { "task_key": "ingest_excel" }
      ],
      "pipeline_task": { "pipeline_id": "<SILVER_PIPELINE_ID>" }
    },
    {
      "task_key": "gold_pipeline",
      "depends_on": [{ "task_key": "silver_pipeline" }],
      "pipeline_task": { "pipeline_id": "<GOLD_PIPELINE_ID>" }
    },
    {
      "task_key": "score_fraud",
      "depends_on": [{ "task_key": "gold_pipeline" }],
      "notebook_task": {
        "notebook_path": "/Workspace/<your-folder>/session-5-serving/batch_score_fraud"
      },
      "environment_key": "serverless"
    },
    {
      "task_key": "score_rtw",
      "depends_on": [{ "task_key": "gold_pipeline" }],
      "notebook_task": {
        "notebook_path": "/Workspace/<your-folder>/session-5-serving/batch_score_rtw"
      },
      "environment_key": "serverless"
    },
    {
      "task_key": "data_quality",
      "depends_on": [
        { "task_key": "score_fraud" },
        { "task_key": "score_rtw" }
      ],
      "notebook_task": {
        "notebook_path": "/Workspace/<your-folder>/session-3-gold/data_quality_view"
      },
      "environment_key": "serverless"
    }
  ],
  "environments": [
    {
      "environment_key": "serverless",
      "spec": { "client": "2" }
    }
  ],
  "queue": { "enabled": true }
}
